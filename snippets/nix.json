{
  "flake": {
    "prefix": "flake",
    "body": [
      "{",
      "  description = \"${1:desc}\";",
      "",
      "  inputs = {",
      "    nixpkgs.url = \"github:NixOS/nixpkgs/nixos-unstable\";",
      "  };",
      "",
      "  outputs = { self, nixpkgs }:",
      "    let",
      "      system = \"${2:x86_64-linux}\";",
      "      pkgs = import nixpkgs { inherit system; };",
      "    in {",
      "      devShells.${2}.default = pkgs.mkShell {",
      "        packages = with pkgs; [ ${3:} ];",
      "      };",
      "    };",
      "}"
    ],
    "description": "Basic flake with devShell"
  },
  "mkShell": {
    "prefix": "mkshell",
    "body": [
      "pkgs.mkShell {",
      "  packages = with pkgs; [ ${1:} ];",
      "}"
    ],
    "description": "mkShell template"
  },
  "overlay": {
    "prefix": "overlay",
    "body": [
      "final: prev: {",
      "  ${1:pkg} = prev.${1}.overrideAttrs (old: {",
      "    ${0}",
      "  });",
      "}"
    ],
    "description": "Overlay template"
  }
}
